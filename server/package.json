{
  "name": "cpms-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CPMS backend - Express + TypeScript + MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test:models": "tsx src/scripts/testModels.ts",
    "test:auth": "tsx src/scripts/testAuth.ts",
    "test:projects": "tsx src/scripts/testProjects.ts",
    "test:employees": "tsx src/scripts/testEmployees.ts",
    "test:tasks": "tsx src/scripts/testTasks.ts",
    "test:materials": "tsx src/scripts/testMaterials.ts",
    "test:vendors": "tsx src/scripts/testVendors.ts",
    "test:dashboard": "tsx src/scripts/testDashboard.ts",
    "test:expenses": "tsx src/scripts/testExpenses.ts",
    "test:invoices": "tsx src/scripts/testInvoices.ts",
    "test:notifications": "tsx src/scripts/testNotifications.ts",
    "test:reports": "tsx src/scripts/testReports.ts",
    "test:dailyreports": "tsx src/scripts/testDailyReports.ts",
    "seed:dev": "tsx src/scripts/seedDev.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pdfkit": "^0.15.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
